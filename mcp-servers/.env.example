# 有活 MCP — 环境变量（C/B 端通用）
#
# 本地开发：可只配 YOUHUO_BASE_URL（测试网关）
# 云托管：必须配生产 YOUHUO_BASE_URL；镜像已设 YOUHUO_REQUIRE_BASE_URL=1

# 生产: https://hopped-gateway-service-sops.hopped.com.cn
# 测试: https://hopped-gateway-service-sops-test.hopped.com.cn
YOUHUO_BASE_URL=https://hopped-gateway-service-sops-test.hopped.com.cn

# 云托管镜像内置（本地 stdio 可不设）
# YOUHUO_REQUIRE_BASE_URL=1
# YOUHUO_REJECT_TEST_GATEWAY=1
# YOUHUO_AUTH_DB_PATH=/tmp/youhuo_auth.db
# YOUHUO_MCP_CONFIRM_TOKEN_STORE=/tmp/youhuo_mcp_confirm_tokens.json
# YOUHUO_MCP_AUDIT_LOG_PATH=/tmp/youhuo_mcp_audit.log

# 写操作门禁（生产禁止设为 false）
# YOUHUO_MCP_WRITE_ENABLED=true
# YOUHUO_MCP_CONFIRM_TOKEN_REQUIRED=true
